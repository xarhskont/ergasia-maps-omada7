{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true,
        "jest": true,
        "mocha": true
    },
    "extends": ["eslint:recommended", "prettier"],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": ["html"],
    "rules": {
        "no-unused-vars": [
            "warn",
            { "vars": "all", "args": "after-used", "ignoreRestSiblings": false }
        ],
        "no-console": "off",
        "semi": ["error", "always"],
        "quotes": ["error", "single", { "allowTemplateLiterals": true }],
        "eqeqeq": ["error", "always"],
        "no-var": "error",
        "prefer-const": "error",
        "curly": ["error", "all"]
    }
}
